# Copy to .env and fill in. .env is git-ignored. PAPER/keys only — no real-money creds.
# Alpaca PAPER trading (Increment D / Phase 7) — must be the paper endpoint
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_ENDPOINT=https://paper-api.alpaca.markets
# Gemini (intelligence layer, Increment C)
GOOGLE_API_KEY=
# Reddit (PRAW, non-commercial OAuth tier)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=quantlab-capstone/0.1 by <your_reddit_user>
